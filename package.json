{
  "name": "scoreboard-voleibol",
  "version": "1.0.0",
  "icon": "icon.ico",
  "description": "",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "start:linux": "electron . --no-sandbox",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.gorilasoftware.scoreboard-voleibol",
    "productName": "Scoreboard Voleibol",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/sqlite3/**/*",
      "**/node_modules/node-notifier/**/*",
      "views/**/*",
      "resources/**/*",
      "server/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "include": "installer.nsh"
    },
    "extraFiles": [
      "scoreboard.sqlite"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.ico"
    },
    "linux": {
      "target": "AppImage"
    },
    "extraResources": [
      {
        "from": "scoreboard.sqlite",
        "to": "scoreboard.sqlite"
      }
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@electron/rebuild": "^0.0.0",
    "electron": "^40.3.0",
    "electron-builder": "^26.7.0",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "dependencies": {
    "express": "^5.2.1",
    "fs-extra": "^11.1.1",
    "jquery": "^3.6.4",
    "moment": "^2.30.1",
    "mysql": "^2.18.1",
    "mysql2": "^3.2.4",
    "node-notifier": "^10.0.1",
    "nodemailer": "^8.0.1",
    "serial-number": "^1.3.0",
    "socket.io": "^4.8.1",
    "sqlite3": "^5.0.2"
  },
  "overrides": {
    "node-gyp": "^10.0.0"
  }
}
